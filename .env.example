# Hotfy SDK keys — copy this file to `.env` and fill in your values.
# These are loaded automatically by Expo at build time as `process.env.EXPO_PUBLIC_*`.

# Identidade do app no Hotfy Console (wrapper config + device tokens + push events).
# Hotfy Console → seu app → Settings → "API Key".
EXPO_PUBLIC_HOTFY_APP_API_KEY=

# Identidade do app no Hotfy CDP (eventos, atribuição, ad revenue).
# Hotfy CDP → seu app → Settings → "API Keys".
EXPO_PUBLIC_HOTFY_CDP_API_KEY=

# When "true", initializes the Hotfy SDK with `debug: true` on all modules.
# This emits verbose console.* logs (wrapper config resolution, CDP HTTP calls,
# device-token sync state, etc.) — visible in the in-app debug console "Logs"
# tab. Leave empty / "false" in production builds.
EXPO_PUBLIC_IS_DEVELOPMENT=true
